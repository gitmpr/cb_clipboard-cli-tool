# =============================================================================
# MAIN FUNCTION
# =============================================================================

cb() {
    # Check if running in appropriate context - cb is designed for interactive use only
    # Allow override for testing purposes
    if [[ "${CB_ALLOW_NONINTERACTIVE:-}" != "1" ]]; then
        # Check if we have a proper terminal environment (stdin, stdout, stderr all connected to TTY)
        # This is a better indicator than shell flags for actual interactive usage
        if [[ ! -t 0 || ! -t 1 || ! -t 2 ]]; then
            # Special case: allow stdin from pipe if stdout/stderr are terminals (echo "text" | cb)
            if [[ ! -t 0 && -t 1 && -t 2 ]]; then
                # This is likely: echo "something" | cb (which is valid)
                debug_log "Allowing piped stdin to terminal"
            # Special case: allow stdout redirect if stdin/stderr are terminals (cb > file)
            elif [[ -t 0 && ! -t 1 && -t 2 ]]; then
                # This is likely: cb > file (paste mode, which is valid)
                debug_log "Allowing stdout redirect from terminal"
            else
                # No proper terminal environment - likely running in a script
                echo "Error: cb is designed for interactive use only. It will not work correctly in scripts due to OSC 52 terminal requirements." >&2
                echo "Hint: cb is meant for terminal users, not automation. Use other clipboard tools for scripting." >&2
                return 1
            fi
        fi
    fi

    # Reset global flags
    CB_FORCE_STRING=false
    CB_COPY_REALPATH=false

    # Parse flags - support both before and after arguments (flexible positioning)
    local args=()
    local s_flag_count=0
    local r_flag_count=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -s)
                ((s_flag_count++))
                if [[ $s_flag_count -gt 1 ]]; then
                    error_exit "Invalid option: $1 (flag already specified)"
                fi
                CB_FORCE_STRING=true
                shift
                ;;
            -r)
                ((r_flag_count++))
                if [[ $r_flag_count -gt 1 ]]; then
                    error_exit "Invalid option: $1 (flag already specified)"
                fi
                CB_COPY_REALPATH=true
                shift
                ;;
            -h|--help) show_help; return 0 ;;
            -*)
                # Only reject single-letter flags we recognize
                if [[ "$1" =~ ^-[a-zA-Z]$ ]]; then
                    error_exit "Invalid option: $1"
                else
                    # Treat multi-character or unknown dash-prefixed strings as literal arguments
                    args+=("$1")
                    shift
                fi
                ;;
            *) args+=("$1"); shift ;;
        esac
    done

    # Restore arguments after flag processing
    set -- "${args[@]}"

    # Validate flag combinations
    if [[ $CB_COPY_REALPATH == true && $CB_FORCE_STRING == true ]]; then
        error_exit "Cannot use -r and -s flags together"
    fi

    # Check for stdin + argument conflicts
    if [[ $# -gt 0 && ! -t 0 ]]; then
        error_exit "Cannot accept both stdin and an argument"
    fi

    # Validate realpath flag requirements
    if [[ $CB_COPY_REALPATH == true && $# -eq 0 ]]; then
        error_exit "-r flag requires a file path argument"
    fi

    # Detect paste mode (output is redirected/piped) - but only if no stdin and no args
    if [[ ! -t 1 && -t 0 && $# -eq 0 ]]; then
        handle_paste
        return
    fi

    # Dispatch based on argument count and context
    case $# in
        0)
            if [[ -t 0 ]]; then
                show_help >&2
                return 1
            else
                handle_stdin
            fi
            ;;
        1)
            local arg="$1"

            if [[ $CB_COPY_REALPATH == true ]]; then
                handle_realpath "$arg"
            elif [[ $CB_FORCE_STRING == true ]]; then
                handle_string "$arg"
            elif [[ -L "$arg" && ! -e "$arg" ]]; then
                # Check for broken symlinks first (before -e check)
                error_exit "Cannot copy '$arg' - it is a broken symbolic link\nHint: Use -s flag to copy the literal string '$arg' instead"
            elif [[ -f "$arg" ]]; then
                handle_file "$arg"
            elif [[ -e "$arg" ]]; then
                # More specific error messages for different file types
                if [[ -d "$arg" ]]; then
                    if [[ -L "$arg" ]]; then
                        error_exit "Cannot copy '$arg' - it is a symbolic link to a directory, not a regular file\nHint: Use -s flag to copy the literal string '$arg' instead"
                    else
                        error_exit "Cannot copy '$arg' - it is a directory, not a regular file\nHint: Use -s flag to copy the literal string '$arg' instead"
                    fi
                elif [[ -p "$arg" ]]; then
                    error_exit "Cannot copy '$arg' - it is a named pipe (FIFO), not a regular file\nHint: Use -s flag to copy the literal string '$arg' instead"
                elif [[ -c "$arg" ]]; then
                    error_exit "Cannot copy '$arg' - it is a character device, not a regular file\nHint: Use -s flag to copy the literal string '$arg' instead"
                elif [[ -b "$arg" ]]; then
                    error_exit "Cannot copy '$arg' - it is a block device, not a regular file\nHint: Use -s flag to copy the literal string '$arg' instead"
                elif [[ -S "$arg" ]]; then
                    error_exit "Cannot copy '$arg' - it is a Unix domain socket, not a regular file\nHint: Use -s flag to copy the literal string '$arg' instead"
                else
                    error_exit "Cannot copy '$arg' - unknown file type, not a regular file\nHint: Use -s flag to copy the literal string '$arg' instead"
                fi
            else
                handle_string "$arg"
            fi
            ;;
        *)
            error_exit "Too many arguments. Quote your input into a single argument string"
            ;;
    esac
}

