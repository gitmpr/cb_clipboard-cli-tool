#!/usr/bin/env bash

# cb - Universal clipboard utility with clean modular structure
# Simplified version to avoid complex nesting and syntax issues

# =============================================================================
# CONSTANTS AND CONFIGURATION
# =============================================================================

readonly OSC52_TIMEOUT_DEFAULT=2.0
readonly COLOR_RESET=$'\033[0m'
readonly COLOR_ACCENT=$'\033[0;93m'      # Bright yellow
readonly COLOR_SUCCESS=$'\033[0;92m'     # Bright green
readonly COLOR_WARNING=$'\033[0;33m'     # Yellow
readonly COLOR_ERROR=$'\033[0;31m'       # Red
readonly COLOR_MUTED=$'\033[0;90m'       # Bright black/gray
readonly COLOR_INFO=$'\033[0;96m'        # Bright cyan
readonly COLOR_MAGENTA=$'\033[0;95m'     # Bright magenta
readonly COLOR_WHITE=$'\033[1;37m'       # White
readonly COLOR_BLUE=$'\033[0;34m'        # Blue
readonly COLOR_GREEN=$'\033[0;32m'       # Green
readonly COLOR_CYAN=$'\033[0;36m'        # Cyan

# Global flags
CB_FORCE_STRING=false
CB_COPY_REALPATH=false

# =============================================================================
# UTILITY FUNCTIONS
# =============================================================================

debug_log() {
    if [[ "${CB_DEBUG:-0}" == "1" || "${CB_DEBUG:-false}" == "true" ]]; then
        echo "${COLOR_MUTED}[DEBUG] $*${COLOR_RESET}" >&2
    fi
}

error_exit() {
    echo "${COLOR_ERROR}Error: $*${COLOR_RESET}" >&2
    exit 1
}

warn() {
    echo "${COLOR_WARNING}Warning: $*${COLOR_RESET}" >&2
}

info() {
    echo "${COLOR_INFO}$*${COLOR_RESET}" >&2
}

success() {
    echo "${COLOR_SUCCESS}$*${COLOR_RESET}" >&2
}

# =============================================================================
# CORE FUNCTIONALITY
# =============================================================================

copy_to_clipboard() {
    local content="$1"
    local b64_content

    # Check if stderr is connected to a terminal for OSC 52 sequences
    if [[ ! -t 2 ]]; then
        error_exit "Cannot copy to clipboard: stderr must be connected to a terminal for OSC 52 sequences"
    fi

    if [[ ${#content} -eq 0 ]]; then
        b64_content=""  # Empty string to clear clipboard
    else
        b64_content=$(printf '%s' "$content" | base64 -w0)
    fi

    if [[ -n "$b64_content" ]]; then
        printf '\033]52;c;%s\033\\' "$b64_content" >&2
    else
        # Send empty OSC 52 to clear clipboard
        printf '\033]52;c;\033\\' >&2
    fi
}

paste_from_clipboard() {
    local script_dir=$(dirname "${BASH_SOURCE[0]}")

    command -v python3 >/dev/null 2>&1 || error_exit "python3 required for paste functionality"

    debug_log "Attempting to paste from clipboard with timeout: ${OSC52_TIMEOUT_DEFAULT}s"

    python3 "$script_dir/cb_osc52_paste.py" "$OSC52_TIMEOUT_DEFAULT"
    return $?
}

get_absolute_path() {
    local path="$1"

    if command -v realpath >/dev/null 2>&1; then
        realpath -m "$path" 2>/dev/null || echo "$path"
    else
        # Fallback implementation - handle relative paths properly
        if [[ "$path" = /* ]]; then
            # Already absolute
            echo "$path"
        elif [[ -e "$path" ]]; then
            # File exists - get absolute path via cd
            echo "$(cd "$(dirname "$path")" && pwd)/$(basename "$path")"
        else
            # File doesn't exist - resolve relative to current directory
            local current_dir=$(pwd)
            local resolved_path

            # Handle . and .. components
            if [[ "$path" =~ ^\.\.?/ ]] || [[ "$path" =~ /\.\.?/ ]] || [[ "$path" =~ /\.\.?$ ]]; then
                # Path contains . or .. - try to resolve via dirname if parent exists
                local parent_dir=$(dirname "$path")
                local filename=$(basename "$path")

                if [[ -d "$parent_dir" ]]; then
                    echo "$(cd "$parent_dir" && pwd)/$filename"
                else
                    # Parent doesn't exist, just prepend current directory
                    echo "$current_dir/$path"
                fi
            else
                # Simple relative path without . or ..
                echo "$current_dir/$path"
            fi
        fi
    fi
}

analyze_text() {
    local text="$1"
    local line_count=0
    local char_count=${#text}
    local has_trailing_nl="false"

    if [[ $char_count -gt 0 ]]; then
        # Detect trailing newline reliably
        if [[ "${text: -1}" == $'\n' ]]; then
            has_trailing_nl="true"
        fi

        # wc -l counts newline characters; if there is no trailing newline
        # but content exists, the line count is wc_lines + 1; otherwise wc_lines
        local wc_lines
        wc_lines=$(printf '%s' "$text" | wc -l)
        if [[ "$has_trailing_nl" == "true" ]]; then
            line_count=$wc_lines
        else
            line_count=$((wc_lines + 1))
        fi
    fi

    echo "$line_count $char_count $has_trailing_nl"
}

is_binary_file() {
    local filename="$1"

    # First check with file command if available
    if command -v file >/dev/null 2>&1; then
        local file_type
        file_type=$(file -b "$filename" 2>/dev/null || echo "data")

        # Known binary patterns
        if [[ "$file_type" =~ (ELF|PE32|Mach-O|executable.*binary|shared object|relocatable|archive.*compressed|gzip|zip|tar|image data|audio|video|font data) ]]; then
            return 0  # is binary
        fi

        # Check for generic binary indicators
        if [[ "$file_type" =~ (^data$|^Non-ISO.*binary|^Little-endian|^Big-endian) ]] || ! [[ "$file_type" =~ (text|script|JSON|XML|ASCII|UTF-8) ]]; then
            # Additional check: look for null bytes - use direct od on file
            if od -An -tx1 -N 1024 "$filename" 2>/dev/null | tr -d ' \n' | grep -q '00' 2>/dev/null; then
                return 0  # is binary
            fi
        fi
    fi

    return 1  # not binary or cannot determine
}

get_newline_description() {
    local has_trailing_nl="$1"
    local context="$2"

    if [[ "$has_trailing_nl" == "true" ]]; then
        case "$context" in
            stdin) echo "${COLOR_MUTED}(ends with newline)${COLOR_RESET}" ;;
            file) echo "${COLOR_MUTED}(file ends with newline - standard format)${COLOR_RESET}" ;;
            *) echo "${COLOR_MUTED}(ends with newline)${COLOR_RESET}" ;;
        esac
    else
        case "$context" in
            stdin) echo "${COLOR_INFO}(no trailing newline)${COLOR_RESET}" ;;
            file) echo "${COLOR_WARNING}(file missing final newline - not POSIX compliant)${COLOR_RESET}" ;;
            *) echo "${COLOR_INFO}(no trailing newline)${COLOR_RESET}" ;;
        esac
    fi
}

# =============================================================================
# MAIN HANDLERS
# =============================================================================

handle_stdin() {
    debug_log "Reading from stdin"

    local input
    input=$(cat; echo x)
    input=${input%x}  # Preserve trailing newlines

    local analysis=($(analyze_text "$input"))
    local line_count=${analysis[0]}
    local char_count=${analysis[1]}
    local has_trailing_nl=${analysis[2]}

    local nl_desc
    nl_desc=$(get_newline_description "$has_trailing_nl" "stdin")

    if [[ $char_count -eq 0 ]]; then
        info "Copying empty content from stdin"
    else
        info "Copying content from stdin"
    fi

    copy_to_clipboard "$input"
    if [[ $char_count -eq 0 ]]; then
        echo "${COLOR_MAGENTA}✓ Clipboard cleared (empty stdin content)${COLOR_RESET}" >&2
    else
        echo "${COLOR_MAGENTA}✓ Stdin content copied to clipboard: ${COLOR_ACCENT}$line_count${COLOR_MAGENTA} lines, ${COLOR_ACCENT}$char_count${COLOR_MAGENTA} characters${COLOR_RESET}" >&2
    fi
    echo -e "  $nl_desc" >&2
}

handle_realpath() {
    local path="$1"
    local absolute_path=$(get_absolute_path "$path")

    if [[ -e "$path" ]]; then
        info "Copying absolute path of '$path'"
    else
        warn "'$path' does not exist - copying hypothetical absolute path"
    fi

    copy_to_clipboard "$absolute_path"
    success "✓ Path copied to clipboard: ${COLOR_ACCENT}${absolute_path}${COLOR_SUCCESS}"
}

handle_file() {
    local filepath="$1"

    [[ -r "$filepath" ]] || error_exit "Cannot read file '$filepath' - permission denied"

    # Check if binary
    if is_binary_file "$filepath"; then
        warn "Copying binary file '$filepath' - content will be copied as-is"
    else
        info "Copying text file '$filepath'"
    fi

    # Preserve trailing newlines: use sentinel trick to avoid command substitution trimming
    local content
    content=$(cat "$filepath" 2>/dev/null; printf x) || error_exit "Failed to read file '$filepath'"
    content=${content%x}

    local analysis=($(analyze_text "$content"))
    local line_count=${analysis[0]}
    local char_count=${analysis[1]}
    local has_trailing_nl=${analysis[2]}

    local nl_desc
    nl_desc=$(get_newline_description "$has_trailing_nl" "file")

    if [[ $char_count -eq 0 ]]; then
        info "File '$filepath' is empty"
    fi

    copy_to_clipboard "$content"
    if [[ $char_count -eq 0 ]]; then
        echo "${COLOR_SUCCESS}✓ Clipboard cleared (empty file)${COLOR_RESET}" >&2
    else
        echo "${COLOR_SUCCESS}✓ File contents copied to clipboard: ${COLOR_ACCENT}$line_count${COLOR_SUCCESS} lines, ${COLOR_ACCENT}$char_count${COLOR_SUCCESS} characters${COLOR_RESET}" >&2
    fi
    echo -e "  $nl_desc" >&2
}

handle_string() {
    local text="$1"

    if [[ $CB_FORCE_STRING == true ]]; then
        info "Copying literal string argument (forced with -s flag)"
    else
        info "Copying string argument"
    fi

    local analysis=($(analyze_text "$text"))
    local line_count=${analysis[0]}
    local char_count=${analysis[1]}
    local has_trailing_nl=${analysis[2]}

    local nl_desc
    nl_desc=$(get_newline_description "$has_trailing_nl" "string")

    if [[ $char_count -eq 0 ]]; then
        info "Copying empty string"
    fi

    copy_to_clipboard "$text"
    if [[ $char_count -eq 0 ]]; then
        echo "${COLOR_WARNING}✓ Clipboard cleared (empty string)${COLOR_RESET}" >&2
    else
        echo "${COLOR_WARNING}✓ String copied to clipboard: ${COLOR_ACCENT}$line_count${COLOR_WARNING} lines, ${COLOR_ACCENT}$char_count${COLOR_WARNING} characters${COLOR_RESET}" >&2
    fi
    echo -e "  $nl_desc" >&2
}

handle_paste() {
    paste_from_clipboard
}

