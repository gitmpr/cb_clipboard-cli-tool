    printf "%sExamples:%s\n" "$COLOR_WARNING" "$COLOR_RESET"
    printf "  %scat%s %sfile.txt%s %s|%s %scb%s         %s# Copy file via pipe%s\n" "$COLOR_WHITE" "$COLOR_RESET" "$COLOR_GREEN" "$COLOR_RESET" "$COLOR_WHITE" "$COLOR_RESET" "$COLOR_WHITE" "$COLOR_RESET" "$COLOR_MAGENTA" "$COLOR_RESET"
    printf "  %scb%s %simportant.log%s          %s# Copy file contents%s\n" "$COLOR_WHITE" "$COLOR_RESET" "$COLOR_GREEN" "$COLOR_RESET" "$COLOR_MAGENTA" "$COLOR_RESET"
    printf "  %scb%s %s-s%s %sfilename.txt%s        %s# Copy literal string%s\n" "$COLOR_WHITE" "$COLOR_RESET" "$COLOR_BLUE" "$COLOR_RESET" "$COLOR_GREEN" "$COLOR_RESET" "$COLOR_MAGENTA" "$COLOR_RESET"
    printf "  %scb%s %sfilename.txt%s %s-s%s        %s# Copy literal string (flexible)%s\n" "$COLOR_WHITE" "$COLOR_RESET" "$COLOR_GREEN" "$COLOR_RESET" "$COLOR_BLUE" "$COLOR_RESET" "$COLOR_MAGENTA" "$COLOR_RESET"
    printf "  %scb%s %s-r%s %sscript.sh%s           %s# Copy absolute path%s\n" "$COLOR_WHITE" "$COLOR_RESET" "$COLOR_BLUE" "$COLOR_RESET" "$COLOR_GREEN" "$COLOR_RESET" "$COLOR_MAGENTA" "$COLOR_RESET"
    printf "  %secho%s %s-n%s %s\"\"%s %s|%s %scb%s           %s# Clear clipboard%s\n" "$COLOR_WHITE" "$COLOR_RESET" "$COLOR_BLUE" "$COLOR_RESET" "$COLOR_GREEN" "$COLOR_RESET" "$COLOR_WHITE" "$COLOR_RESET" "$COLOR_WHITE" "$COLOR_RESET" "$COLOR_MAGENTA" "$COLOR_RESET"
    printf "  %scb%s %s|%s %sgrep%s %spattern%s         %s# Paste and filter%s\n" "$COLOR_WHITE" "$COLOR_RESET" "$COLOR_WHITE" "$COLOR_RESET" "$COLOR_WHITE" "$COLOR_RESET" "$COLOR_GREEN" "$COLOR_RESET" "$COLOR_MAGENTA" "$COLOR_RESET"
    printf "  %scb%s %s>%s %sbackup.txt%s           %s# Paste to file%s\n" "$COLOR_WHITE" "$COLOR_RESET" "$COLOR_WHITE" "$COLOR_RESET" "$COLOR_GREEN" "$COLOR_RESET" "$COLOR_MAGENTA" "$COLOR_RESET"
end

# =============================================================================
# MAIN FUNCTION
# =============================================================================

function cb
    # Check if running in appropriate context - cb is designed for interactive use only
    # Allow override for testing purposes
    if test "$CB_ALLOW_NONINTERACTIVE" != "1"
        # Check if we have a proper terminal environment (stdin, stdout, stderr all connected to TTY)
        # This is a better indicator than shell flags for actual interactive usage
        if not isatty stdin; or not isatty stdout; or not isatty stderr
            # Special case: allow stdin from pipe if stdout/stderr are terminals (echo "text" | cb)
            if not isatty stdin; and isatty stdout; and isatty stderr
                # This is likely: echo "something" | cb (which is valid)
                debug_log "Allowing piped stdin to terminal"
            # Special case: allow stdout redirect if stdin/stderr are terminals (cb > file)
            else if isatty stdin; and not isatty stdout; and isatty stderr
                # This is likely: cb > file (paste mode, which is valid)
                debug_log "Allowing stdout redirect from terminal"
            else
                # No proper terminal environment - likely running in a script
                echo "Error: cb is designed for interactive use only. It will not work correctly in scripts due to OSC 52 terminal requirements." >&2
                echo "Hint: cb is meant for terminal users, not automation. Use other clipboard tools for scripting." >&2
                return 1
            end
        end
    end

    # Reset global flags
    set -g CB_FORCE_STRING false
    set -g CB_COPY_REALPATH false

    # Parse flags - support both before and after arguments (flexible positioning)
    set -l args
    set -l s_flag_count 0
    set -l r_flag_count 0

    for arg in $argv
        switch $arg
            case -s
                set s_flag_count (math $s_flag_count + 1)
                if test $s_flag_count -gt 1
                    error_exit "Invalid option: $arg (flag already specified)"
                end
                set -g CB_FORCE_STRING true
            case -r
                set r_flag_count (math $r_flag_count + 1)
                if test $r_flag_count -gt 1
                    error_exit "Invalid option: $arg (flag already specified)"
                end
                set -g CB_COPY_REALPATH true
            case -h --help
                show_help
                return 0
            case '-*'
                # Only reject single-letter flags we recognize
                if string match -q -r '^-[a-zA-Z]$' -- "$arg"
                    error_exit "Invalid option: $arg"
                else
                    # Treat multi-character or unknown dash-prefixed strings as literal arguments
                    set -a args $arg
                end
            case '*'
                set -a args $arg
        end
    end

    # Validate flag combinations
    if test "$CB_COPY_REALPATH" = true; and test "$CB_FORCE_STRING" = true
        error_exit "Cannot use -r and -s flags together"
    end

    # Check for stdin + argument conflicts
    if test (count $args) -gt 0; and not isatty stdin
        error_exit "Cannot accept both stdin and an argument"
    end

    # Validate realpath flag requirements
    if test "$CB_COPY_REALPATH" = true; and test (count $args) -eq 0
        error_exit "-r flag requires a file path argument"
    end

    # Detect paste mode (output is redirected/piped) - but only if no stdin and no args
    if not isatty stdout; and isatty stdin; and test (count $args) -eq 0
        handle_paste
        return
    end

    # Dispatch based on argument count and context
    switch (count $args)
        case 0
            if isatty stdin
                show_help >&2
                return 1
            else
                handle_stdin
            end
        case 1
            set -l arg $args[1]

            if test "$CB_COPY_REALPATH" = true
                handle_realpath "$arg"
            else if test "$CB_FORCE_STRING" = true
                handle_string "$arg"
            else if test -L "$arg"; and not test -e "$arg"
                # Check for broken symlinks first (before -e check)
                error_exit "Cannot copy '$arg' - it is a broken symbolic link\nHint: Use -s flag to copy the literal string '$arg' instead"
            else if test -f "$arg"
                handle_file "$arg"
            else if test -e "$arg"
                # More specific error messages for different file types
                if test -d "$arg"
                    if test -L "$arg"
                        error_exit "Cannot copy '$arg' - it is a symbolic link to a directory, not a regular file\nHint: Use -s flag to copy the literal string '$arg' instead"
                    else
                        error_exit "Cannot copy '$arg' - it is a directory, not a regular file\nHint: Use -s flag to copy the literal string '$arg' instead"
                    end
                else if test -p "$arg"
                    error_exit "Cannot copy '$arg' - it is a named pipe (FIFO), not a regular file\nHint: Use -s flag to copy the literal string '$arg' instead"
                else if test -c "$arg"
                    error_exit "Cannot copy '$arg' - it is a character device, not a regular file\nHint: Use -s flag to copy the literal string '$arg' instead"
                else if test -b "$arg"
                    error_exit "Cannot copy '$arg' - it is a block device, not a regular file\nHint: Use -s flag to copy the literal string '$arg' instead"
                else if test -S "$arg"
                    error_exit "Cannot copy '$arg' - it is a Unix domain socket, not a regular file\nHint: Use -s flag to copy the literal string '$arg' instead"
                else
                    error_exit "Cannot copy '$arg' - unknown file type, not a regular file\nHint: Use -s flag to copy the literal string '$arg' instead"
                end
            else
                handle_string "$arg"
            end
        case '*'
            error_exit "Too many arguments. Quote your input into a single argument string"
    end
end

# =============================================================================
# SCRIPT EXECUTION
# =============================================================================

# Only execute if script is run directly (not sourced)
# $_ is always empty in fish, so we use status flags instead:
#   not is-interactive: running as a non-interactive script (not in an interactive shell)
#   not is-block: not inside a block context (fish -c "source ... && ..." sets is-block=true)
# Together these are only both true when running directly as the main script.
if not status --is-interactive; and not status --is-block
    cb $argv
end