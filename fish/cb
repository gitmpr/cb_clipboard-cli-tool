#!/usr/bin/env fish

# cb - Universal clipboard utility with clean modular structure
# Fish shell implementation

# =============================================================================
# CONSTANTS AND CONFIGURATION
# =============================================================================

set -g OSC52_TIMEOUT_DEFAULT 2.0
set -g COLOR_RESET \e'[0m'
set -g COLOR_ACCENT \e'[0;93m'      # Bright yellow
set -g COLOR_SUCCESS \e'[0;92m'     # Bright green
set -g COLOR_WARNING \e'[0;33m'     # Yellow
set -g COLOR_ERROR \e'[0;31m'       # Red
set -g COLOR_MUTED \e'[0;90m'       # Bright black/gray
set -g COLOR_INFO \e'[0;96m'        # Bright cyan
set -g COLOR_MAGENTA \e'[0;95m'     # Bright magenta
set -g COLOR_WHITE \e'[1;37m'       # White
set -g COLOR_BLUE \e'[0;34m'        # Blue
set -g COLOR_GREEN \e'[0;32m'       # Green
set -g COLOR_CYAN \e'[0;36m'        # Cyan

# Global flags - use global scope for these
set -g CB_FORCE_STRING false
set -g CB_COPY_REALPATH false

# =============================================================================
# UTILITY FUNCTIONS
# =============================================================================

function debug_log
    if test "$CB_DEBUG" = "1"; or test "$CB_DEBUG" = "true"
        printf '%s[DEBUG] %s%s\n' "$COLOR_MUTED" "$argv" "$COLOR_RESET" >&2
    end
end

function error_exit
    printf '%sError: %s%s\n' "$COLOR_ERROR" "$argv" "$COLOR_RESET" >&2
    exit 1
end

function warn
    printf '%sWarning: %s%s\n' "$COLOR_WARNING" "$argv" "$COLOR_RESET" >&2
end

function info
    printf '%s%s%s\n' "$COLOR_INFO" "$argv" "$COLOR_RESET" >&2
end

function success
    printf '%s%s%s\n' "$COLOR_SUCCESS" "$argv" "$COLOR_RESET" >&2
end

# =============================================================================
# CORE FUNCTIONALITY
# =============================================================================

function copy_to_clipboard
    set -l content $argv[1]

    # Check if stderr is connected to a terminal for OSC 52 sequences
    # (skipped when CB_ALLOW_NONINTERACTIVE=1 to allow test contexts)
    if test "$CB_ALLOW_NONINTERACTIVE" != "1"
        if not isatty stderr
            error_exit "Cannot copy to clipboard: stderr must be connected to a terminal for OSC 52 sequences"
        end
    end

    # Declare at function scope first — fish's `set -l` is block-scoped (not function-scoped
    # like bash's `local`), so variables declared inside if/end blocks are gone afterwards.
    set -l b64_content ""
    if test (string length -- "$content") -gt 0
        set b64_content (printf '%s' "$content" | base64 -w0)
    end

    if test -n "$b64_content"
        printf '\e]52;c;%s\e\\' "$b64_content" >&2
    else
        # Send empty OSC 52 to clear clipboard
        printf '\e]52;c;\e\\' >&2
    end
end

function paste_from_clipboard
    set -l script_dir (dirname (status current-filename))

    if not command -v python3 >/dev/null 2>&1
        error_exit "python3 required for paste functionality"
    end

    debug_log "Attempting to paste from clipboard with timeout: $OSC52_TIMEOUT_DEFAULT"s

    python3 "$script_dir/cb_osc52_paste.py" $OSC52_TIMEOUT_DEFAULT
    return $status
end

function get_absolute_path
    set -l path $argv[1]

    if command -v realpath >/dev/null 2>&1
        realpath -m "$path" 2>/dev/null; or echo "$path"
    else
        # Fallback implementation - handle relative paths properly
        if string match -q '/*' -- "$path"
            # Already absolute
            echo "$path"
        else if test -e "$path"
            # File exists - get absolute path via cd
            echo (cd (dirname "$path") && pwd)/(basename "$path")
        else
            # File doesn't exist - resolve relative to current directory
            set -l current_dir (pwd)

            # Handle . and .. components
            if string match -q -r '^\.\.?/' -- "$path"; or string match -q -r '/\.\.?/' -- "$path"; or string match -q -r '/\.\.?$' -- "$path"
                # Path contains . or .. - try to resolve via dirname if parent exists
                set -l parent_dir (dirname "$path")
                set -l filename (basename "$path")

                if test -d "$parent_dir"
                    echo (cd "$parent_dir" && pwd)/$filename
                else
                    # Parent doesn't exist, just prepend current directory
                    echo "$current_dir/$path"
                end
            else
                # Simple relative path without . or ..
                echo "$current_dir/$path"
            end
        end
    end
end

function analyze_text
    set -l text $argv[1]
    set -l line_count 0
    set -l char_count (string length -- "$text")
    set -l has_trailing_nl false

    if test "$char_count" -gt 0
        # Detect trailing newline: check last character via substring.
        # Note: string match glob '*\n' in fish matches literal backslash-n (not a newline),
        # so we use string sub to get the last char and compare via regex.
        set -l last_char (string sub -s -1 -- "$text")
        if string match -qr '\n' -- "$last_char"
            set has_trailing_nl true
        end

        # Count lines properly
        if test "$has_trailing_nl" = true
            set line_count (printf '%s' "$text" | wc -l)
        else
            set line_count (math (printf '%s' "$text" | wc -l) + 1)
        end
    end

    # Use printf with newlines to create separate items instead of echo with spaces
    printf '%s\n%s\n%s\n' $line_count $char_count $has_trailing_nl
end

function is_binary_file
    set -l filename $argv[1]

    # First check with file command if available
    if command -v file >/dev/null 2>&1
        set -l file_type (file -b "$filename" 2>/dev/null; or echo "data")

        # Known binary patterns
        if string match -q -r '(ELF|PE32|Mach-O|executable.*binary|shared object|relocatable|archive.*compressed|gzip|zip|tar|image data|audio|video|font data)' -- "$file_type"
            return 0  # is binary
        end

        # Check for generic binary indicators
        if string match -q -r '(^data$|^Non-ISO.*binary|^Little-endian|^Big-endian)' -- "$file_type"; or not string match -q -r '(text|script|JSON|XML|ASCII|UTF-8)' -- "$file_type"
            # Additional check: look for null bytes - use direct od on file
            if od -An -tx1 -N 1024 "$filename" 2>/dev/null | tr -d ' \n' | grep -q '00' 2>/dev/null
                return 0  # is binary
            end
        end
    end

    return 1  # not binary or cannot determine
end

function get_newline_description
    set -l has_trailing_nl $argv[1]
    set -l context $argv[2]

    if test "$has_trailing_nl" = true
        switch $context
            case stdin
                echo "$COLOR_MUTED(ends with newline)$COLOR_RESET"
            case file
                echo "$COLOR_MUTED(file ends with newline - standard format)$COLOR_RESET"
            case '*'
                echo "$COLOR_MUTED(ends with newline)$COLOR_RESET"
        end
    else
        switch $context
            case stdin
                echo "$COLOR_INFO(no trailing newline)$COLOR_RESET"
            case file
                echo "$COLOR_WARNING(file missing final newline - not POSIX compliant)$COLOR_RESET"
            case '*'
                echo "$COLOR_INFO(no trailing newline)$COLOR_RESET"
        end
    end
end

# =============================================================================
# MAIN HANDLERS
# =============================================================================

function handle_stdin
    debug_log "Reading from stdin"

    # Read stdin: use read -z to read the full stream as one string, preserving
    # all embedded and trailing newlines (fish command substitution would strip/re-split them).
    set -l input
    read -z input

    set -l analysis (analyze_text "$input")
    set -l line_count $analysis[1]
    set -l char_count $analysis[2]
    set -l has_trailing_nl $analysis[3]

    set -l nl_desc (get_newline_description "$has_trailing_nl" "stdin")

    if test $char_count -eq 0
        info "Copying empty content from stdin"
    else
        info "Copying content from stdin"
    end

    copy_to_clipboard "$input"
    if test $char_count -eq 0
        echo "$COLOR_MAGENTA✓ Clipboard cleared (empty stdin content)$COLOR_RESET" >&2
    else
        echo "$COLOR_MAGENTA✓ Stdin content copied to clipboard: $COLOR_ACCENT$line_count$COLOR_MAGENTA lines, $COLOR_ACCENT$char_count$COLOR_MAGENTA characters$COLOR_RESET" >&2
    end
    echo "  $nl_desc" >&2
end

function handle_realpath
    set -l path $argv[1]
    set -l absolute_path (get_absolute_path "$path")

    if test -e "$path"
        info "Copying absolute path of '$path'"
    else
        warn "'$path' does not exist - copying hypothetical absolute path"
    end

    copy_to_clipboard "$absolute_path"
    success "✓ Path copied to clipboard: $COLOR_ACCENT$absolute_path$COLOR_SUCCESS"
end

function handle_file
    set -l filepath $argv[1]

    if not test -r "$filepath"
        error_exit "Cannot read file '$filepath' - permission denied"
    end

    # Check if binary
    if is_binary_file "$filepath"
        warn "Copying binary file '$filepath' - content will be copied as-is"
    else
        info "Copying text file '$filepath'"
    end

    # Read file content: use read -z to get the full file as one string, preserving
    # all embedded and trailing newlines (fish command substitution would strip/re-split them).
    # Note: read -z exits 1 on empty input (valid for an empty file), so no `or error_exit` —
    # file existence/readability is already guaranteed by the `test -r` check above.
    set -l content ""
    read -z content < "$filepath"

    set -l analysis (analyze_text "$content")
    set -l line_count $analysis[1]
    set -l char_count $analysis[2]
    set -l has_trailing_nl $analysis[3]

    set -l nl_desc (get_newline_description "$has_trailing_nl" "file")

    if test $char_count -eq 0
        info "File '$filepath' is empty"
    end

    copy_to_clipboard "$content"
    if test $char_count -eq 0
        echo "$COLOR_SUCCESS✓ Clipboard cleared (empty file)$COLOR_RESET" >&2
    else
        echo "$COLOR_SUCCESS✓ File contents copied to clipboard: $COLOR_ACCENT$line_count$COLOR_SUCCESS lines, $COLOR_ACCENT$char_count$COLOR_SUCCESS characters$COLOR_RESET" >&2
    end
    echo "  $nl_desc" >&2
end

function handle_string
    set -l text $argv[1]

    if test "$CB_FORCE_STRING" = true
        info "Copying literal string argument (forced with -s flag)"
    else
        info "Copying string argument"
    end

    set -l analysis (analyze_text "$text")
    set -l line_count $analysis[1]
    set -l char_count $analysis[2]
    set -l has_trailing_nl $analysis[3]

    set -l nl_desc (get_newline_description "$has_trailing_nl" "string")

    if test $char_count -eq 0
        info "Copying empty string"
    end

    copy_to_clipboard "$text"
    if test $char_count -eq 0
        echo "$COLOR_WARNING✓ Clipboard cleared (empty string)$COLOR_RESET" >&2
    else
        echo "$COLOR_WARNING✓ String copied to clipboard: $COLOR_ACCENT$line_count$COLOR_WARNING lines, $COLOR_ACCENT$char_count$COLOR_WARNING characters$COLOR_RESET" >&2
    end
    echo "  $nl_desc" >&2
end

function handle_paste
    paste_from_clipboard
end

